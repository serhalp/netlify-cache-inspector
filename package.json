{
  "name": "netlify-cache-inspector",
  "private": true,
  "description": "Inspect and compare cache headers for requests to Netlify sites",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate": "nuxt generate",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:unit": "vitest run",
    "test": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:unit",
    "typecheck": "nuxi typecheck",
    "zizmor": "zizmor --pedantic .",
    "zizmor:fix": "zizmor --pedantic --fix ."
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.0",
    "@netlify/nuxt": "0.3.6",
    "date-fns": "^4.1.0",
    "h3": "^1.15.0",
    "highlight.js": "^11.11.1",
    "nuxt": "^4.4.2",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.0",
    "@nuxt/test-utils": "^4.0.0",
    "@unocss/nuxt": "^66.6.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.3",
    "knip": "^6.0.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.51.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.5.0"
}
