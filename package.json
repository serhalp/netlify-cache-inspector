{
  "name": "netlify-cache-inspector",
  "private": true,
  "description": "Inspect and compare cache headers for requests to Netlify sites",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate": "nuxt generate",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test:unit": "vitest run",
    "test": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test:unit",
    "typecheck": "nuxi typecheck",
    "zizmor": "zizmor --pedantic .",
    "zizmor:fix": "zizmor --pedantic --fix ."
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@netlify/nuxt": "0.3.9",
    "date-fns": "^4.4.0",
    "h3": "^1.15.11",
    "highlight.js": "^11.11.1",
    "nuxt": "npm:nuxt-nightly@4.5.0-29716853.29bdf786",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@e18e/eslint-plugin": "^0.5.1",
    "@nuxt/test-utils": "^4.0.3",
    "@unocss/nuxt": "^66.7.2",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "knip": "^6.20.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.17.0"
}
